generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  darkId    String   @unique
  handle    String   @default("Anon")
  ipHash    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  memberships RoomMember[]
  messages    Message[]

  @@index([expiresAt])
}

model Room {
  id        String     @id @default(uuid())
  darkIdA   String
  darkIdB   String?
  status    String     @default("PENDING")
  createdAt DateTime   @default(now())
  expiresAt DateTime

  members  RoomMember[]
  messages Message[]

  @@index([expiresAt])
  @@index([status, expiresAt])
}

model RoomMember {
  roomId    String
  sessionId String
  joinedAt  DateTime @default(now())

  room    Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([roomId, sessionId])
  @@index([sessionId])
}

model Message {
  id         String    @id @default(uuid())
  roomId     String
  senderId   String
  type       String
  body       String?
  recalledAt DateTime?
  createdAt  DateTime  @default(now())

  room        Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender      Session      @relation(fields: [senderId], references: [id])
  attachments Attachment[]

  @@index([roomId, createdAt])
}

model Attachment {
  id         String   @id @default(uuid())
  messageId  String
  storageKey String
  mimeType   String
  byteSize   Int
  width      Int?
  height     Int?
  durationMs Int?
  checksum   String
  createdAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}
