# =============================================================
# Phòng Kín - Environment Configuration
# =============================================================

# Database (SQLite)
DATABASE_URL="file:./dev.db"

# Redis (cache + Socket.IO scaling)
REDIS_URL="redis://localhost:6379"

# MinIO / S3 (file storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="phongkin"
MINIO_USE_SSL="false"

# SePay - Thanh toán (Sandbox values cho dev)
SEPAY_ACCOUNT_NUMBER="0000000000"
SEPAY_BANK="MBBank"
SEPAY_ACCOUNT_NAME="PHONG KIN"
SEPAY_API_KEY="dev_sandbox_key"

# Environment
NODE_ENV="development"

# WebSocket URL (cho client)
NEXT_PUBLIC_WS_URL="ws://localhost:3000"

# App URL (dùng để build invite link đầy đủ)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
