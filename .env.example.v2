# =============================================================================
# DarkTalk - Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# Environment (development | production)
NODE_ENV="development"

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# Local dev (docker-compose.dev.yml):
DATABASE_URL="postgresql://postgres:darktalk_dev@localhost:5432/darktalk"

# Oracle Cloud / production example:
# DATABASE_URL="postgresql://darktalk:STRONG_PASSWORD@localhost:5432/darktalk"

# =============================================================================
# Redis (for Socket.IO adapter, rate limit, invite cache)
# =============================================================================
# Local dev:
REDIS_URL="redis://localhost:6379"

# Upstash (free tier 500K commands/month):
# REDIS_URL="rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379"

# Session secret (generate with: openssl rand -base64 32)
SESSION_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# WebSocket URL (used by client to connect)
NEXT_PUBLIC_WS_URL="ws://localhost:3000"

# Allowed CORS origins (comma-separated)
# ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# =============================================================================
# Cloudflare R2 (S3-compatible object storage, FREE 10GB vĩnh viễn)
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# =============================================================================
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key"
R2_SECRET_ACCESS_KEY="your_r2_secret_key"
R2_BUCKET="darktalk-uploads"

# Optional: custom domain for public bucket (set up via Cloudflare dashboard)
# R2_PUBLIC_URL="https://uploads.yourdomain.com"

# =============================================================================
# Oracle Cloud / AWS specific (only set when deploying)
# =============================================================================
# PORT=3000

# =============================================================================
# DuckDNS (free dynamic DNS - auto-updates IP every 5 min)
# Get from: https://www.duckdns.org/
# Set up a cron: curl "https://www.duckdns.org/update?domains=YOURNAME&token=YOUR_TOKEN&ip="
# =============================================================================
# DUCKDNS_DOMAIN="darktalk"
# DUCKDNS_TOKEN="your-duckdns-token"
